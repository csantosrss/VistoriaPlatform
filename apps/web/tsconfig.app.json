{
  "extends": "@vistoria/config/tsconfig/react.json",
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"],
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "node_modules", "dist"]
}
