# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (consumed by Prisma) ---
DATABASE_URL=postgresql://vistoria:vistoria@localhost:5432/vistoria?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://vistoria:vistoria@localhost:5672
RABBITMQ_EXCHANGE=vistoria.events

# --- SMTP (MailHog em dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- JWT RS256 (placeholder; gerar com: openssl genrsa -out private.pem 2048) ---
# Em dev, se vazio, o módulo gera um par RSA efêmero em memória e loga um warning.
# Em produção (NODE_ENV=production), são obrigatórios.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=vistoria-platform
JWT_AUDIENCE=vistoria-api
JWT_EXPIRES_IN=15m

# --- Observabilidade ---
SERVICE_NAME=vistoria-api
