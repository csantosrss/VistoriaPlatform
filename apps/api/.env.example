# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (consumed by Prisma) ---
DATABASE_URL=postgresql://vistoria:vistoria@localhost:5433/vistoria?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://vistoria:vistoria@localhost:5672
RABBITMQ_EXCHANGE=vistoria.events

# --- SMTP (MailHog em dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- JWT RS256 (placeholder; gerar com: openssl genrsa -out private.pem 2048) ---
# Em dev, se vazio, o módulo gera um par RSA efêmero em memória e loga um warning.
# Em produção (NODE_ENV=production), são obrigatórios.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=vistoria-platform
JWT_AUDIENCE=vistoria-api
JWT_EXPIRES_IN=15m

# --- Observabilidade ---
SERVICE_NAME=vistoria-api

# --- Parceiros de integração (Sprint 03 IN) ---
# Secrets de dev intencionalmente determinísticos para que `pnpm test:e2e`
# consiga assinar payloads válidos. Em prod, substituir por valores secretos.
PARTNER_HTTP_TIMEOUT_MS=10000
REDE_VISTORIAS_API_URL=https://api.redevistorias.com.br
REDE_VISTORIAS_API_KEY=
REDE_VISTORIAS_WEBHOOK_SECRET=dev-rv-webhook-secret-do-not-use-in-prod
CONCEITUAL_API_URL=https://api.conceitual.com.br
CONCEITUAL_API_KEY=
CONCEITUAL_WEBHOOK_SECRET=dev-conceitual-webhook-secret-do-not-use-in-prod
