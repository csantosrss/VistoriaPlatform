// Prisma schema — Vistoria Platform
// Este sprint introduz apenas o esqueleto multi-tenant + auditoria.
// As entidades de domínio (Vistoria, Imovel, Comodo, etc) serão adicionadas pelo
// agente BE em sprints subsequentes, sempre com tenantId e seguindo o padrão de
// tenant isolation definido em CLAUDE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  auditLogs    AuditLog[]
  vistorias    Vistoria[]
  agendaSlots  AgendaSlot[]
  coberturas   VistoriadorCobertura[]

  @@map("tenants")
}

enum Role {
  ADMIN
  GESTOR
  VISTORIADOR
  CLIENTE
  PARCEIRO
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  email        String
  name         String
  passwordHash String?
  roles        Role[]   @default([])
  active       Boolean  @default(true)
  /// ProviderId do vistoriador: `interno`, `rede-vistorias` ou `conceitual`.
  /// Sprint 22 BE — obrigatório quando `roles` inclui VISTORIADOR (validado
  /// no service). Nullable no DB para preservar users criados antes da
  /// migration; backfill manual via `PATCH /users/:id` quando o user passar
  /// a precisar de agenda/cobertura.
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  vistoriasAtribuidas Vistoria[] @relation("VistoriadorAtribuido")
  agendaSlots         AgendaSlot[] @relation("VistoriadorAgenda")
  coberturas          VistoriadorCobertura[] @relation("VistoriadorCobertura")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, providerId])
  @@map("users")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  userId        String?  @db.Uuid
  action        String
  resourceType  String
  resourceId    String?
  before        Json?
  after         Json?
  correlationId String?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

enum StatusVistoria {
  SOLICITADA
  ROTEADA
  AGENDADA
  CONFIRMADA
  EM_EXECUCAO
  LAUDO_PENDENTE
  LAUDO_APROVADO
  CONCLUIDA
  CANCELADA
}

enum TipoVistoria {
  ENTRADA
  SAIDA
}

model Vistoria {
  id       String         @id @default(uuid()) @db.Uuid
  tenantId String         @db.Uuid
  status   StatusVistoria @default(SOLICITADA)
  tipo     TipoVistoria

  /// Identificador do imóvel no sistema externo (ERP imobiliário,
  /// Salesforce etc.). Obrigatório no DTO de criação desde Sprint 22;
  /// nullable no DB para preservar vistorias criadas antes da migration.
  /// Indexado por `(tenantId, codigoImovelExterno)` para busca rápida —
  /// múltiplas vistorias por código é esperado (entrada + saída + ...).
  codigoImovelExterno String?

  enderecoLogradouro  String
  enderecoNumero      String
  enderecoComplemento String?
  enderecoBairro      String
  enderecoCidade      String
  enderecoUf          String  @db.VarChar(2)
  enderecoCep         String  @db.VarChar(9)

  contatoNome     String
  contatoTelefone String
  contatoEmail    String?
  observacoes     String?

  vistoriadorId   String? @db.Uuid
  providerId      String?

  agendadoPara    DateTime?
  concluidoEm     DateTime?
  canceladoEm     DateTime?
  canceladoMotivo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vistoriador User?               @relation("VistoriadorAtribuido", fields: [vistoriadorId], references: [id], onDelete: SetNull)
  transicoes  VistoriaTransicao[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, vistoriadorId])
  @@index([tenantId, codigoImovelExterno])
  @@map("vistorias")
}

model VistoriaTransicao {
  id            String          @id @default(uuid()) @db.Uuid
  vistoriaId    String          @db.Uuid
  tenantId      String          @db.Uuid
  de            StatusVistoria?
  para          StatusVistoria
  motivo        String?
  executadoPor  String?         @db.Uuid
  correlationId String?
  createdAt     DateTime        @default(now())

  vistoria Vistoria @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)

  @@index([vistoriaId])
  @@index([tenantId, createdAt])
  @@map("vistoria_transicoes")
}

/// Janela de agenda do vistoriador. Sprint 17 BE.
/// `disponivel` distingue libera (true) de bloqueio (false) — mesma tabela
/// para os dois conceitos. O motor de regras de routing pode no futuro
/// consultar `(disponivel = true) AND (inicio, fim) cobre o slot desejado`.
model AgendaSlot {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  vistoriadorId String   @db.Uuid
  inicio        DateTime
  fim           DateTime
  disponivel    Boolean  @default(true)
  motivo        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vistoriador User   @relation("VistoriadorAgenda", fields: [vistoriadorId], references: [id], onDelete: Cascade)

  @@index([tenantId, vistoriadorId, inicio])
  @@index([tenantId, inicio, fim])
  @@map("agenda_slots")
}

/// Área geográfica em que o vistoriador atende. Sprint 22 BE.
///
/// Hierarquia:
///   (uf, null, null)         → cobre toda a UF
///   (uf, cidade, null)       → cobre toda a cidade (qualquer bairro)
///   (uf, cidade, bairro)     → cobre só o bairro
///
/// Múltiplas linhas por vistoriador são esperadas. Redundância é
/// **bloqueada** pelo service com 409 — não cria `(SP, São Paulo, null)`
/// quando já existe `(SP, null, null)` (ou vice-versa).
///
/// Routing não consulta esta tabela nesta sprint. Integração com
/// `ProviderRoutingService` (provider+UF) e seleção por vistoriador
/// específico fica para sprint futura.
model VistoriadorCobertura {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  vistoriadorId String   @db.Uuid
  uf            String   @db.VarChar(2)
  cidade        String?
  bairro        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vistoriador User   @relation("VistoriadorCobertura", fields: [vistoriadorId], references: [id], onDelete: Cascade)

  @@index([tenantId, vistoriadorId])
  @@index([tenantId, uf, cidade, bairro])
  @@map("vistoriador_cobertura")
}
