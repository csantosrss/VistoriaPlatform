// Prisma schema — Vistoria Platform
// Este sprint introduz apenas o esqueleto multi-tenant + auditoria.
// As entidades de domínio (Vistoria, Imovel, Comodo, etc) serão adicionadas pelo
// agente BE em sprints subsequentes, sempre com tenantId e seguindo o padrão de
// tenant isolation definido em CLAUDE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  auditLogs AuditLog[]
  vistorias Vistoria[]

  @@map("tenants")
}

enum Role {
  ADMIN
  GESTOR
  VISTORIADOR
  CLIENTE
  PARCEIRO
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  email        String
  name         String
  passwordHash String?
  roles        Role[]   @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  vistoriasAtribuidas Vistoria[] @relation("VistoriadorAtribuido")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  userId        String?  @db.Uuid
  action        String
  resourceType  String
  resourceId    String?
  before        Json?
  after         Json?
  correlationId String?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

enum StatusVistoria {
  SOLICITADA
  ROTEADA
  AGENDADA
  CONFIRMADA
  EM_EXECUCAO
  LAUDO_PENDENTE
  LAUDO_APROVADO
  CONCLUIDA
  CANCELADA
}

enum TipoVistoria {
  ENTRADA
  SAIDA
}

model Vistoria {
  id       String         @id @default(uuid()) @db.Uuid
  tenantId String         @db.Uuid
  status   StatusVistoria @default(SOLICITADA)
  tipo     TipoVistoria

  enderecoLogradouro  String
  enderecoNumero      String
  enderecoComplemento String?
  enderecoBairro      String
  enderecoCidade      String
  enderecoUf          String  @db.VarChar(2)
  enderecoCep         String  @db.VarChar(9)

  contatoNome     String
  contatoTelefone String
  contatoEmail    String?
  observacoes     String?

  vistoriadorId   String? @db.Uuid
  providerId      String?

  agendadoPara    DateTime?
  concluidoEm     DateTime?
  canceladoEm     DateTime?
  canceladoMotivo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vistoriador User?               @relation("VistoriadorAtribuido", fields: [vistoriadorId], references: [id], onDelete: SetNull)
  transicoes  VistoriaTransicao[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, vistoriadorId])
  @@map("vistorias")
}

model VistoriaTransicao {
  id            String          @id @default(uuid()) @db.Uuid
  vistoriaId    String          @db.Uuid
  tenantId      String          @db.Uuid
  de            StatusVistoria?
  para          StatusVistoria
  motivo        String?
  executadoPor  String?         @db.Uuid
  correlationId String?
  createdAt     DateTime        @default(now())

  vistoria Vistoria @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)

  @@index([vistoriaId])
  @@index([tenantId, createdAt])
  @@map("vistoria_transicoes")
}
