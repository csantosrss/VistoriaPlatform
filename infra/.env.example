# PostgreSQL
POSTGRES_USER=vistoria
POSTGRES_PASSWORD=vistoria
POSTGRES_DB=vistoria
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=vistoria
RABBITMQ_PASS=vistoria
