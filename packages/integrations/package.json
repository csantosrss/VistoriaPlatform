{
  "name": "@vistoria/integrations",
  "version": "0.1.0",
  "private": true,
  "description": "Adapters de parceiros (Rede Vistorias, Conceitual, Interno) + webhook handlers + RMQ subscribers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vistoria/api-contracts": "workspace:*",
    "amqplib": "^0.10.4",
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/swagger": "^8.0.0",
    "express": "^4.0.0 || ^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/swagger": "^8.0.7",
    "@nestjs/testing": "^10.4.7",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@vistoria/config": "workspace:*",
    "express": "^4.21.1",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "moduleNameMapper": {
      "^@vistoria/api-contracts$": "<rootDir>/../api-contracts/src/index.ts",
      "^@vistoria/api-contracts/(.*)\\.js$": "<rootDir>/../api-contracts/src/$1",
      "^@vistoria/api-contracts/(.*)$": "<rootDir>/../api-contracts/src/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
